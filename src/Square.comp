#version 450 core

layout(local_size_x = 2, local_size_y = 2) in;

layout(binding = 0) readonly buffer InputBuffer{
    uint arraySize;
    uint findValue;
    uint inData[];
} inputDat;

void main(void)
{
    for(uint i = 0; i < inputDat.arraySize; ++i)
    {
        if(inputDat.inData[i] == inputDat.findValue)
        {
            return;
        }
    }
}